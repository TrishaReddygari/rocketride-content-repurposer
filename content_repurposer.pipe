{
	"components": [
		{
			"id": "chat_1",
			"provider": "chat",
			"config": { "hideForm": true, "mode": "Source", "parameters": {}, "type": "chat" },
			"ui": { "position": { "x": 20, "y": 400 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		},

		{
			"id": "agent_linkedin_1",
			"provider": "agent_rocketride",
			"config": {
				"instructions": ["You are a LinkedIn-post writer. Your sole task is to rewrite the long-form blog post the user provides as a LinkedIn post that follows EVERY rule below. Do not deviate.\n\nHARD RULES:\n- Total length must be under 1,300 characters. Count them.\n- First line is a single punchy hook. No 'In today's fast-paced world' fluff. No questions in the hook.\n- Body is 2 to 4 short paragraphs, each focused on ONE specific insight from the source post.\n- Generous line breaks for mobile scannability — every paragraph separated by a blank line.\n- End with a soft, specific question that invites a real comment. Avoid 'Thoughts?' / 'Agree?' clichés.\n- No hashtags anywhere.\n- Voice: confident, first-person, like a developer telling another developer something they actually learned.\n\nOutput format: ONLY the LinkedIn post text. No preamble, no labels, no markdown headers, no quotes around the output."],
				"max_waves": 2,
				"parameters": {}
			},
			"input": [{ "lane": "questions", "from": "chat_1" }],
			"ui": { "position": { "x": 240, "y": 80 }, "measured": { "width": 150, "height": 86 }, "nodeType": "default", "formDataValid": true }
		},
		{
			"id": "agent_twitter_1",
			"provider": "agent_rocketride",
			"config": {
				"instructions": ["You are an X (Twitter) thread writer. Your sole task is to rewrite the long-form blog post the user provides as an X thread that follows EVERY rule below. Do not deviate.\n\nHARD RULES:\n- Exactly 5 to 8 tweets. No more, no fewer.\n- Each tweet must be 280 characters or fewer. Count them.\n- Number every tweet at the start: '1/', '2/', '3/', etc.\n- Tweet 1 is the hook — make someone stop scrolling. No question in the hook.\n- Each subsequent tweet delivers ONE concrete idea, example, or takeaway from the source.\n- No hashtags.\n- The final tweet lands on a specific takeaway, not a generic 'follow me' CTA.\n- Voice: punchy, opinionated, first-person.\n\nOutput format: tweets one per line, separated by ONE blank line between tweets. No preamble, no labels, no markdown headers."],
				"max_waves": 2,
				"parameters": {}
			},
			"input": [{ "lane": "questions", "from": "chat_1" }],
			"ui": { "position": { "x": 240, "y": 280 }, "measured": { "width": 150, "height": 86 }, "nodeType": "default", "formDataValid": true }
		},
		{
			"id": "agent_devto_1",
			"provider": "agent_rocketride",
			"config": {
				"instructions": ["You are a dev.to article writer. Your sole task is to rewrite the long-form blog post the user provides as a short dev.to article in markdown that follows the EXACT structure below.\n\nUSE THIS EXACT MARKDOWN STRUCTURE — no extra sections, no missing sections:\n\n# {specific, clickable title}\n\n> TL;DR: {2-sentence summary}\n\n{1 to 2 short paragraphs of context — what is this about and why a developer reader should care}\n\n## Key takeaways\n\n- **{takeaway 1}** — one sentence\n- **{takeaway 2}** — one sentence\n- **{takeaway 3}** — one sentence\n\n## Read the full version\n\n{One sentence prompting the reader to read the source post.}\n\nVoice: technical, warm, first-person, no marketing-speak. Output ONLY the markdown above — no preamble, no extra headers, no labels around the output."],
				"max_waves": 2,
				"parameters": {}
			},
			"input": [{ "lane": "questions", "from": "chat_1" }],
			"ui": { "position": { "x": 240, "y": 480 }, "measured": { "width": 150, "height": 86 }, "nodeType": "default", "formDataValid": true }
		},
		{
			"id": "agent_instagram_1",
			"provider": "agent_rocketride",
			"config": {
				"instructions": ["You are an Instagram caption writer. Your sole task is to rewrite the long-form blog post the user provides as an Instagram caption that follows EVERY rule below. Do not deviate.\n\nHARD RULES:\n- Total caption length: 800 to 1,500 characters (excluding hashtags).\n- Open with a single scroll-stopping line — the part visible before 'see more'.\n- Generous line breaks between thoughts — Instagram captions are skimmed.\n- Inject ONE specific moment, detail, or quote from the source post — no generic platitudes.\n- Voice: warm, authentic, conversational — like sharing this with a friend, not broadcasting.\n- End the caption text with a question that genuinely invites comments.\n- After the caption text, leave EXACTLY ONE blank line, then add 5 to 10 relevant hashtags on a single line.\n- Light emoji use is OK; do not overdo it.\n\nOutput format: ONLY the caption + hashtags. No preamble, no labels, no markdown headers, no quotes around the output."],
				"max_waves": 2,
				"parameters": {}
			},
			"input": [{ "lane": "questions", "from": "chat_1" }],
			"ui": { "position": { "x": 240, "y": 680 }, "measured": { "width": 150, "height": 86 }, "nodeType": "default", "formDataValid": true }
		},

		{
			"id": "llm_openai_linkedin_1",
			"provider": "llm_openai",
			"config": {
				"profile": "openai-4o",
				"openai-4o": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" },
				"parameters": {}
			},
			"control": [{ "classType": "llm", "from": "agent_linkedin_1" }],
			"ui": { "position": { "x": 460, "y": 40 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		},
		{
			"id": "llm_openai_twitter_1",
			"provider": "llm_openai",
			"config": {
				"profile": "openai-4o",
				"openai-4o": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" },
				"parameters": {}
			},
			"control": [{ "classType": "llm", "from": "agent_twitter_1" }],
			"ui": { "position": { "x": 460, "y": 240 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		},
		{
			"id": "llm_openai_devto_1",
			"provider": "llm_openai",
			"config": {
				"profile": "openai-4o",
				"openai-4o": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" },
				"parameters": {}
			},
			"control": [{ "classType": "llm", "from": "agent_devto_1" }],
			"ui": { "position": { "x": 460, "y": 440 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		},
		{
			"id": "llm_openai_instagram_1",
			"provider": "llm_openai",
			"config": {
				"profile": "openai-4o",
				"openai-4o": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" },
				"parameters": {}
			},
			"control": [{ "classType": "llm", "from": "agent_instagram_1" }],
			"ui": { "position": { "x": 460, "y": 640 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		},

		{
			"id": "memory_internal_linkedin_1",
			"provider": "memory_internal",
			"config": { "type": "memory_internal" },
			"control": [{ "classType": "memory", "from": "agent_linkedin_1" }],
			"ui": { "position": { "x": 460, "y": 120 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		},
		{
			"id": "memory_internal_twitter_1",
			"provider": "memory_internal",
			"config": { "type": "memory_internal" },
			"control": [{ "classType": "memory", "from": "agent_twitter_1" }],
			"ui": { "position": { "x": 460, "y": 320 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		},
		{
			"id": "memory_internal_devto_1",
			"provider": "memory_internal",
			"config": { "type": "memory_internal" },
			"control": [{ "classType": "memory", "from": "agent_devto_1" }],
			"ui": { "position": { "x": 460, "y": 520 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		},
		{
			"id": "memory_internal_instagram_1",
			"provider": "memory_internal",
			"config": { "type": "memory_internal" },
			"control": [{ "classType": "memory", "from": "agent_instagram_1" }],
			"ui": { "position": { "x": 460, "y": 720 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		},

		{
			"id": "response_answers_1",
			"provider": "response_answers",
			"config": { "laneName": "answers" },
			"input": [
				{ "lane": "answers", "from": "agent_linkedin_1" },
				{ "lane": "answers", "from": "agent_twitter_1" },
				{ "lane": "answers", "from": "agent_devto_1" },
				{ "lane": "answers", "from": "agent_instagram_1" }
			],
			"ui": { "position": { "x": 700, "y": 400 }, "measured": { "width": 150, "height": 66 }, "nodeType": "default", "formDataValid": true }
		}
	],
	"project_id": "aae9082d-2ad9-4a25-8c9e-536b05670d86",
	"viewport": { "x": 0, "y": 0, "zoom": 1 },
	"version": 1
